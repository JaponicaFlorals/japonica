---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const weddings = (await getCollection('weddings')).sort((a,b)=>a.data.order-b.data.order);
const tlist = await getCollection('testimonials');
const t = tlist.find(x=>x.data.show_on==='portfolio') || tlist[0];
const quote = t ? t.body.trim() : '';
const data = Object.fromEntries(weddings.map(w=>[w.slug, {
  title: w.data.couple,
  venue: `${w.data.venue} · ${w.data.date}`,
  photographer: w.data.photographer || '',
  photographerUrl: w.data.photographer_url || '',
  feature: w.data.feature || '',
  featureUrl: w.data.feature_url || '',
  review: w.data.review || '',
  images: w.data.gallery.map(i=>'/'+i),
}]));
const blurbs = Object.fromEntries(await Promise.all(weddings.map(async w=>[w.slug, w.body.trim()])));
---
<BaseLayout title="Portfolio · Japonica" description="Real Sydney weddings by Japonica — a selection of recent floral work." current="portfolio" fontItalic={true}>
  <header class="page-header">
    <div class="crumb"><span class="lspc lspc-32">Japonica &middot; Real weddings</span></div>
    <h1>Portfolio</h1>
    <p class="subline">A selection of recent Sydney weddings, each one designed around the couple and the room.</p>
  </header>

  <section class="gallery">
    <div class="gallery-grid">
      {weddings.map(w => (
        <button type="button" class="case" data-wedding={w.slug}>
          <div class="case-frame"><img src={`/${w.data.cover}`} alt={`${w.data.couple} together at their ceremony`} /><span class="case-cue"><span class="lspc lspc-22">View wedding</span></span></div>
          <div class="case-meta"><span class="lspc lspc-32">{w.data.venue} &middot; {w.data.date}</span></div>
          <h2 set:html={w.data.couple.replace('&','&amp;')}></h2>
          <p>{blurbs[w.slug]}</p>
        </button>
      ))}
    </div>
  </section>

  <section class="testimonial-section">
    <div class="testimonial">
      <div class="quote-glyph reveal">&ldquo;</div>
      <div class="quote-body reveal">{quote}</div>
      <div class="quote-attr reveal"><span class="lspc lspc-34">{t?.data.author}</span></div>
    </div>
  </section>

  <section class="closer">
    <h2 class="reveal">Begin yours</h2>
    <a href="/enquire/" class="cta reveal"><span class="lspc lspc-36">Begin a conversation</span></a>
  </section>

  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Wedding gallery">
    <div class="lb-bar">
      <span class="lb-head"><span class="lb-title" id="lbTitle"></span><span class="lb-meta" id="lbVenue"></span></span>
      <span class="lb-count" id="lbCount"></span>
      <button type="button" class="lb-close" id="lbClose" aria-label="Close gallery">&times;</button>
    </div>
    <div class="lb-stage">
      <button type="button" class="lb-nav" id="lbPrev" aria-label="Previous image">&#8249;</button>
      <img class="lb-img" id="lbImg" src="" alt="" />
      <button type="button" class="lb-nav" id="lbNext" aria-label="Next image">&#8250;</button>
    </div>
    <div class="lb-caption">
      <div class="lb-credit" id="lbCredit"></div>
      <div class="lb-review" id="lbReview"></div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ weddings: data }}>
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lbImg');
  const lbTitle = document.getElementById('lbTitle');
  const lbVenue = document.getElementById('lbVenue');
  const lbCount = document.getElementById('lbCount');
  const lbCredit = document.getElementById('lbCredit');
  const lbReview = document.getElementById('lbReview');
  let current = [], idx = 0;
  function render(){ lbImg.src = current[idx]; lbCount.textContent = (idx+1)+' / '+current.length; }
  function open(key){
    const w = weddings[key]; if(!w) return;
    current = w.images; idx = 0;
    lbTitle.textContent = w.title; lbVenue.textContent = w.venue;
    lbReview.textContent = w.review ? '“'+w.review+'”' : '';
    lbCredit.innerHTML = (w.photographer ? 'Photography · ' + (w.photographerUrl ? '<a href="'+w.photographerUrl+'" target="_blank" rel="noopener">'+w.photographer+'</a>' : w.photographer) : '')
      + (w.feature ? ' &nbsp;·&nbsp; Featured in <a href="'+w.featureUrl+'" target="_blank" rel="noopener">'+w.feature+'</a>' : '');
    render(); lb.classList.add('open'); document.body.style.overflow='hidden';
  }
  function close(){ lb.classList.remove('open'); document.body.style.overflow=''; }
  function step(n){ idx = (idx+n+current.length)%current.length; render(); }
  document.querySelectorAll('.case[data-wedding]').forEach(b=>b.addEventListener('click',()=>open(b.dataset.wedding)));
  document.getElementById('lbClose').addEventListener('click', close);
  document.getElementById('lbPrev').addEventListener('click', ()=>step(-1));
  document.getElementById('lbNext').addEventListener('click', ()=>step(1));
  lb.addEventListener('click', e=>{ if(e.target===lb) close(); });
  document.addEventListener('keydown', e=>{ if(!lb.classList.contains('open')) return; if(e.key==='Escape') close(); else if(e.key==='ArrowLeft') step(-1); else if(e.key==='ArrowRight') step(1); });
</script>

<style>
  .gallery { padding: 80px 56px 160px; max-width: 1500px; margin: 0 auto; }
  .gallery-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 56px; align-items: start; }
  .case { display: block; appearance: none; border: 0; background: transparent; padding: 0; margin: 0; font: inherit; color: inherit; text-align: left; width: 100%; cursor: pointer; }
  .case-frame { position: relative; aspect-ratio: 4/5; overflow: hidden; background: #1f1820; margin-bottom: 28px; }
  .case-frame img { width: 100%; height: 100%; object-fit: cover; transition: transform 1.6s ease; }
  .case:hover .case-frame img { transform: scale(1.03); }
  .case-cue { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(20,15,15,0.32); color: var(--bg); font-size: 11px; text-transform: uppercase; opacity: 0; transition: opacity 0.4s ease; }
  .case:hover .case-cue, .case:focus-visible .case-cue { opacity: 1; }
  .case:focus-visible { outline: 2px solid var(--ink); outline-offset: 4px; }
  .case-meta { font-size: 11px; text-transform: uppercase; color: var(--stone); margin-bottom: 12px; }
  .case h2 { font-family: var(--display); font-size: clamp(28px,3vw,38px); font-weight: 400; line-height: 1.2; margin-bottom: 10px; }
  .case p { font-size: 15px; line-height: 1.7; color: var(--ink-soft); max-width: 440px; }
  .testimonial-section { padding: 140px 56px; background: var(--bg-soft); }
  .closer { padding: 120px 56px 180px; text-align: center; }
  .closer h2 { font-family: var(--display); font-size: clamp(30px,4.4vw,52px); line-height: 1.25; margin-bottom: 48px; font-weight: 400; }
  @media (max-width: 880px) {
    .gallery { padding: 48px 24px 96px; }
    .gallery-grid { grid-template-columns: 1fr; gap: 56px; }
    .testimonial-section { padding: 96px 24px; }
    .closer { padding: 64px 24px 96px; }
  }
</style>
