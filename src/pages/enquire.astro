---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Japonica · Enquire" description="Enquire about wedding florals with Japonica, a Sydney floral studio in Ryde." current="enquire" fontItalic={true}>
<header class="page-header">
  <div class="crumb"><span class="lspc lspc-32">Engaged or planning an event? Congrats</span></div>
  <h1>Enquire</h1>
  <p>We are flower lovers through and through and have been creating floral loveliness for couples and clients for over 10 years. The form below lets you share as much as you would like about your day. The more detail, the more accurate the quote we can return.</p>
  <p>We endeavour to come back to you within 48 hours, unless we are setting up at a venue. Either way, we will always reply as soon as we can.</p>
</header>

<div class="step-indicator">
  <div class="step-pill active"><span class="dot"></span><span class="lspc lspc-32">01 · The basics</span></div>
  <div class="step-line"></div>
  <div class="step-pill"><span class="dot"></span><span class="lspc lspc-32">02 · Your vision</span></div>
</div>

<div class="booking-notes">
  <div class="label"><span class="lspc lspc-36">Before you start</span></div>
  <h3>Minimum spend</h3>
  <p>$1,500 (excluding delivery) for Wednesday to Friday weddings and events. $3,000 for Saturday and Sunday weddings and events. These minimums apply year round.</p>
  <a href="/booking-terms/" class="more"><span class="lspc lspc-28">Read full booking terms</span></a>
</div>

<form class="form-wrap" id="weddingForm" action="https://api.web3forms.com/submit" method="POST">
  <input type="hidden" name="access_key" value="e82cc2e6-c33e-47f8-82d4-4aa865133478">
  <input type="hidden" name="subject" value="New wedding enquiry — Japonica website">
  <input type="hidden" name="from_name" value="Japonica — Wedding enquiry">
  <input type="checkbox" name="botcheck" style="display:none !important" tabindex="-1" autocomplete="off">

  <div class="form-section">
    <h2 class="reveal">Step 01 · The basics</h2>
    <p class="helper reveal">Just enough to get the conversation started. The next step lets you go deeper on the day itself.</p>

    <div class="field-row">
      <div class="field">
        <label>Your name <span class="req">required</span></label>
        <input type="text" name="first_name" placeholder="First name" required>
      </div>
      <div class="field">
        <label>&nbsp;</label>
        <input type="text" name="last_name" placeholder="Last name" required>
      </div>
    </div>

    <div class="field-row">
      <div class="field">
        <label>Your partner's name</label>
        <input type="text" name="partner_first_name" placeholder="First name">
      </div>
      <div class="field">
        <label>&nbsp;</label>
        <input type="text" name="partner_last_name" placeholder="Last name">
      </div>
    </div>

    <div class="field">
      <label>Email <span class="req">required</span></label>
      <input type="email" name="email" placeholder="you@example.com" required>
    </div>

    <div class="field">
      <label>Phone <span class="req">required</span></label>
      <input type="tel" name="phone" placeholder="+61 ..." required>
    </div>

    <div class="field-row">
      <div class="field">
        <label>Wedding or event date</label>
        <input type="date" name="event_date">
      </div>
      <div class="field">
        <label>Approximate guest count</label>
        <input type="number" name="guest_count" placeholder="e.g. 80">
      </div>
    </div>

    <div class="field">
      <label>Ceremony location or venue</label>
      <input type="text" name="ceremony_venue" placeholder="e.g. Athol Hall, Mosman">
    </div>

    <div class="field">
      <label>Reception venue</label>
      <input type="text" name="reception_venue" placeholder="If different from ceremony">
    </div>

    <div class="field">
      <label>What are you enquiring about? <span class="req">required</span></label>
      <div class="checkbox-row">
        <label><input type="checkbox" name="enquiring_about[]" value="Wedding florals"> Wedding florals</label>
        <label><input type="checkbox" name="enquiring_about[]" value="Event florals"> Event florals</label>
        <label><input type="checkbox" name="enquiring_about[]" value="Bridal party"> Bridal party</label>
        <label><input type="checkbox" name="enquiring_about[]" value="Ceremony florals"> Ceremony florals</label>
        <label><input type="checkbox" name="enquiring_about[]" value="Reception florals"> Reception florals</label>
        <label><input type="checkbox" name="enquiring_about[]" value="Additional styling"> Additional styling</label>
      </div>
    </div>

    <div class="field">
      <label>Estimated floral budget <span class="req">required</span></label>
      <input type="text" name="budget" placeholder="$1,500 minimum weekday · $3,000 minimum weekend">
    </div>
  </div>

  <hr class="form-divider">

  <div class="form-section">
    <h2 class="reveal">Step 02 · Your vision</h2>
    <p class="helper reveal">Optional but helpful. The more you share, the closer our quote will land.</p>

    <div class="field">
      <label>Floral vision</label>
      <input type="text" name="floral_vision" placeholder="Theme, palette, references, anything Pinterest-board-shaped">
    </div>

    <div class="field">
      <label>Inspiration link</label>
      <input type="text" name="inspiration_link" placeholder="Paste a Pinterest board or gallery link">
    </div>

    <div class="field">
      <label>Bridal party</label>
      <textarea name="bridal_party" placeholder="Number of bridesmaids and groomsmen, colour, style, preferred florals"></textarea>
    </div>

    <div class="field">
      <label>Ceremony</label>
      <select name="ceremony">
        <option>Select an option</option>
        <option>Plinth Arrangements</option>
        <option>Arbour Florals</option>
        <option>Ground Floral Nest</option>
        <option>Freestanding Floral Towers</option>
        <option>Custom Installation</option>
        <option>Not sure yet</option>
      </select>
    </div>

    <div class="field">
      <label>Additional ceremony items</label>
      <textarea name="additional_ceremony" placeholder="Welcome signage florals, aisle markers, signing table florals, petals, etc."></textarea>
    </div>

    <div class="field">
      <label>Reception tables</label>
      <select name="reception_tables">
        <option>Select an option</option>
        <option>Budvases (petite vases with 2–3 florals and foliage)</option>
        <option>Botanical Arrangement (self contained or in vessel)</option>
        <option>Mix of budvases and botanical arrangements</option>
        <option>Garlands (all foliage or floral and foliage)</option>
        <option>Not sure yet</option>
      </select>
    </div>

    <div class="field">
      <label>Details of tables</label>
      <textarea name="table_details" placeholder="Table shape, guests per table, share platters or plated, separate bridal table or sitting with guests"></textarea>
    </div>

    <div class="field">
      <label>Feature arrangements</label>
      <textarea name="feature_arrangements" placeholder="Suspended installations, gift table, cake florals, bar, entrance"></textarea>
    </div>

    <div class="field">
      <label>Vendors</label>
      <input type="text" name="vendors" placeholder="Photographer, planner, stylist, anyone we should know">
    </div>

    <div class="field">
      <label>How did you hear about us?</label>
      <select name="referral">
        <option>Select an option</option>
        <option>Instagram</option>
        <option>Venue recommendation</option>
        <option>Past couple</option>
        <option>Wedding magazine or directory</option>
        <option>Google search</option>
        <option>Other</option>
      </select>
    </div>

    <div class="field">
      <label>Anything else</label>
      <textarea name="message" placeholder="Anything that will help us land closer on the quote"></textarea>
    </div>
  </div>

  <div class="form-cta">
    <button type="submit" class="cta"><span class="lspc lspc-36">Send enquiry</span></button>
  </div>

</form>
</BaseLayout>

<script>
  const f = document.getElementById('weddingForm');
  if (f) f.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = f.querySelector('button[type="submit"]');
    btn.disabled = true; btn.style.opacity = '0.6';
    try {
      const res = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(f), headers: { 'Accept': 'application/json' } });
      const json = await res.json();
      if (json.success) {
        f.innerHTML = '<div style="text-align:center; padding:80px 0;"><div style="font-family:var(--display); font-size:clamp(26px,3.4vw,40px); color:var(--ink); margin-bottom:16px;">Thank you</div><p style="font-size:17px; color:var(--ink-soft); max-width:520px; margin:0 auto; line-height:1.8;">Your enquiry is on its way. We endeavour to come back to you within 48 hours.</p></div>';
        window.scrollTo({ top: f.offsetTop - 120, behavior: 'smooth' });
      } else { throw new Error(); }
    } catch (err) {
      btn.disabled = false; btn.style.opacity = '1';
      alert('Sorry, something went wrong sending your enquiry. Please email florals@japonica.com.au and we will get straight back to you.');
    }
  });
</script>

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: var(--bg); color: var(--ink); font-family: var(--serif); font-weight: 400; line-height: 1.65; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }

  .lspc { display: inline-block; }
  .lspc-22 { letter-spacing: 0.22em; margin-right: -0.22em; }
  .lspc-28 { letter-spacing: 0.28em; margin-right: -0.28em; }
  .lspc-32 { letter-spacing: 0.32em; margin-right: -0.32em; }
  .lspc-34 { letter-spacing: 0.34em; margin-right: -0.34em; }
  .lspc-36 { letter-spacing: 0.36em; margin-right: -0.36em; }

  nav.top { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; flex-direction: column; align-items: center; gap: 12px; padding: 22px 56px; background: rgba(239, 233, 220, 0.95); backdrop-filter: blur(6px); color: var(--ink); border-bottom: 0.5px solid rgba(53, 42, 53, 0.08); }
  nav.top .mark { font-family: var(--display); font-size: 20px; }
  nav.top .links { display: flex; gap: 36px; font-size: 11px; text-transform: uppercase; font-weight: 500; }
  nav.top .links a { transition: opacity 0.3s; }
  nav.top .links a:hover { opacity: 0.55; }
  nav.top .links a.current { border-bottom: 0.5px solid var(--ink); padding-bottom: 4px; }

  .page-header { padding: 160px 24px 56px; text-align: center; max-width: 820px; margin: 0 auto; }
  .page-header .crumb { font-size: 11px; text-transform: uppercase; color: var(--stone); margin-bottom: 24px; }
  .page-header h1 { font-family: var(--display); font-size: clamp(48px, 7vw, 88px); font-weight: 400; line-height: 1; color: var(--ink); margin-bottom: 32px; }
  .page-header p { font-size: 17px; line-height: 1.85; color: var(--ink-soft); max-width: 640px; margin: 0 auto; }
  .page-header p + p { margin-top: 16px; }

  .reveal { opacity: 0; transform: translateY(28px); transition: opacity 1.1s ease-out, transform 1.1s ease-out; }
  .reveal.in { opacity: 1; transform: translateY(0); }

  /* Step indicator */
  .step-indicator { display: flex; justify-content: center; gap: 56px; padding: 32px 24px 64px; max-width: 820px; margin: 0 auto; }
  .step-pill { display: flex; align-items: center; gap: 12px; font-size: 11px; text-transform: uppercase; color: var(--stone); }
  .step-pill .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--stone); opacity: 0.4; }
  .step-pill.active { color: var(--ink); }
  .step-pill.active .dot { background: var(--ink); opacity: 1; }
  .step-line { width: 80px; height: 0.5px; background: rgba(53, 42, 53, 0.25); align-self: center; }

  /* Form */
  .form-wrap { max-width: 820px; margin: 0 auto; padding: 0 24px 96px; }
  .form-section { margin-bottom: 56px; }
  .form-section h2 { font-family: var(--display); font-size: clamp(28px, 3.4vw, 40px); font-weight: 400; margin-bottom: 12px; line-height: 1.2; }
  .form-section .helper { font-size: 14px; color: var(--ink-soft); line-height: 1.65; margin-bottom: 28px; max-width: 620px; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
  .field { margin-bottom: 24px; }
  .field label { display: block; font-size: 11px; text-transform: uppercase; color: var(--stone); margin-bottom: 10px; letter-spacing: 0.08em; }
  .field label .req { color: var(--ink-soft); margin-left: 6px; font-size: 10px; text-transform: none; letter-spacing: 0; }
  .field input,
  .field select,
  .field textarea { width: 100%; background: rgba(255, 255, 255, 0.4); border: 0.5px solid rgba(53, 42, 53, 0.25); border-radius: var(--radius); padding: 14px 16px; font-family: var(--serif); font-size: 16px; color: var(--ink); transition: border 0.2s ease, background 0.2s ease; }
  .field input:focus,
  .field select:focus,
  .field textarea:focus { outline: none; border-color: var(--ink); background: rgba(255,255,255,0.6); }
  .field textarea { resize: vertical; min-height: 120px; }
  .field .checkbox-row { display: flex; flex-wrap: wrap; gap: 18px 28px; margin-top: 6px; }
  .field .checkbox-row label { display: flex; align-items: center; gap: 10px; font-size: 14px; text-transform: none; letter-spacing: 0; color: var(--ink); margin-bottom: 0; cursor: pointer; }
  .field .checkbox-row input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    margin: 0;
    padding: 0;
    background: rgba(255, 255, 255, 0.4);
    border: 0.5px solid rgba(53, 42, 53, 0.25);
    border-radius: var(--radius);
    cursor: pointer;
    position: relative;
    transition: background 0.2s ease, border-color 0.2s ease;
    flex-shrink: 0;
  }
  .field .checkbox-row input[type="checkbox"]:hover { border-color: var(--ink); background: rgba(255, 255, 255, 0.6); }
  .field .checkbox-row input[type="checkbox"]:checked { background: #3D5876; border-color: #3D5876; }
  .field .checkbox-row input[type="checkbox"]:checked::after {
    content: "";
    position: absolute;
    left: 5px;
    top: 1px;
    width: 5px;
    height: 10px;
    border-right: 1.5px solid var(--bg);
    border-bottom: 1.5px solid var(--bg);
    transform: rotate(45deg);
  }

  .upload-zone { border: 1px dashed rgba(53, 42, 53, 0.35); border-radius: var(--radius); padding: 36px 24px; text-align: center; cursor: pointer; transition: background 0.2s ease, border-color 0.2s ease; }
  .upload-zone:hover { background: rgba(255,255,255,0.3); border-color: var(--ink); }
  .upload-zone .plus { font-size: 28px; color: var(--ink-soft); margin-bottom: 8px; }
  .upload-zone .label { font-size: 14px; color: var(--ink-soft); }

  .form-divider { border: 0; border-top: 0.5px solid rgba(53, 42, 53, 0.15); margin: 64px 0; }

  .form-cta { text-align: center; margin-top: 48px; }
  .cta { display: inline-block; background: var(--ink); color: var(--bg); padding: 22px 64px; border-radius: var(--radius); font-size: 11px; text-transform: uppercase; transition: background 0.4s ease, transform 0.4s ease; border: 0; cursor: pointer; font-family: var(--serif); letter-spacing: 0.36em; }
  .cta:hover { background: #241A24; transform: translateY(-1px); }

  /* Sidebar booking notes */
  .booking-notes { background: var(--bg-warm); padding: 56px 56px; margin-bottom: 56px; max-width: 820px; margin-left: auto; margin-right: auto; border-radius: var(--radius); }
  .booking-notes .label { font-size: 11px; text-transform: uppercase; color: var(--stone); margin-bottom: 14px; }
  .booking-notes h3 { font-family: var(--display); font-size: 24px; font-weight: 400; margin-bottom: 16px; }
  .booking-notes p { font-size: 15px; line-height: 1.75; color: var(--ink-soft); }
  .booking-notes p + p { margin-top: 10px; }
  .booking-notes .more { display: inline-block; margin-top: 16px; font-size: 11px; text-transform: uppercase; color: var(--ink); border-bottom: 0.5px solid rgba(53, 42, 53, 0.35); padding-bottom: 3px; transition: opacity 0.3s; }
  .booking-notes .more:hover { opacity: 0.6; }

  footer { background: var(--ink); color: var(--bg); padding: 96px 56px 48px; }
  .foot-top { max-width: 1400px; margin: 0 auto 72px; text-align: center; padding-bottom: 48px; border-bottom: 0.5px solid rgba(239, 233, 220, 0.15); }
  .foot-mark { font-family: var(--display); font-size: 44px; margin-bottom: 18px; letter-spacing: 0.18em; padding-left: 0.18em; display: inline-block; }
  .foot-philo { font-family: var(--display); font-size: 15px; opacity: 0.7; line-height: 1.7; letter-spacing: 0.02em; }
  .foot-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 56px; max-width: 1400px; margin: 0 auto; }
  .foot-col { text-align: center; }
  .foot-h { font-size: 10px; text-transform: uppercase; opacity: 0.55; margin-bottom: 18px; }
  .foot-line { font-size: 14px; line-height: 1.9; opacity: 0.88; display: block; }
  .foot-line:hover { opacity: 0.6; transition: opacity 0.3s; }
  .foot-meta { max-width: 1400px; margin: 80px auto 0; padding-top: 32px; border-top: 0.5px solid rgba(239, 233, 220, 0.15); display: flex; flex-direction: row; flex-wrap: wrap; justify-content: center; align-items: center; gap: 10px 28px; text-align: center; font-size: 11px; text-transform: uppercase; opacity: 0.5; }
  .foot-meta a { border-bottom: 0.5px solid rgba(239, 233, 220, 0.3); padding-bottom: 1px; }

  @media (max-width: 880px) {
    nav.top { padding: 14px 20px; flex-wrap: wrap; row-gap: 8px; }
    nav.top .mark { font-size: 17px; }
    nav.top .links { width: 100%; justify-content: center; gap: 16px; font-size: 10px; }
    nav.top .links .lspc-28 { letter-spacing: 0.08em; margin-right: -0.08em; }
    .page-header { padding: 120px 24px 40px; }
    .step-indicator { gap: 16px; flex-wrap: wrap; padding: 24px 24px 48px; }
    .step-line { width: 32px; }
    .field-row { grid-template-columns: 1fr; gap: 0; }
    .booking-notes { padding: 32px 24px; margin-left: 24px; margin-right: 24px; }
    .foot-grid { grid-template-columns: 1fr; gap: 40px; }
    .foot-mark { font-size: 34px; }
    footer { padding: 64px 24px 32px; }
    .foot-meta { flex-direction: column; gap: 12px; font-size: 12px; } .foot-line { font-size: 15px; } .foot-h { font-size: 11px; }
  }
</style>
