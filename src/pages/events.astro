---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Japonica · Events" description="Floral design for private celebrations, corporate events and brand activations across Sydney. By appointment, from Ryde." current="events" >
<header class="page-header">
  <div class="crumb"><span class="lspc lspc-32">Japonica · The work</span></div>
  <h1>Events</h1>
  <p class="subline">From private parties and intimate dinners to corporate launches, brand activations and milestone celebrations.</p>
</header>

<div class="hero-strip">
  <img src="/img/events-hero.jpg" alt="Long reception table with a low white floral centrepiece and taper candles">
</div>

<section>
  <div class="intro">
    <h2 class="reveal">Events with Japonica</h2>
    <p class="reveal">From personal parties to large-scale corporate events, Megan brings her experience and considered eye to every brief. Florals designed to reflect the brand or the room you have chosen, not pulled from a template.</p>
    <p class="reveal">Rely on us to create arrangements that turn your event into something people remember. Lush, considered and built for the room.</p>
  </div>
</section>

<section id="enquire" class="closer-section">
  <div class="closer">
    <h2 class="reveal">Tell us what you're planning</h2>
    <a href="/events-enquiry/" class="cta reveal"><span class="lspc lspc-36">Begin a conversation</span></a>
    <div class="closer-byline reveal"><span class="lspc lspc-32">By appointment, from Ryde</span></div>
  </div>
</section>
</BaseLayout>

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { background: var(--bg); color: var(--ink); font-family: var(--serif); font-weight: 400; line-height: 1.65; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }

  .lspc { display: inline-block; }
  .lspc-22 { letter-spacing: 0.22em; margin-right: -0.22em; }
  .lspc-28 { letter-spacing: 0.28em; margin-right: -0.28em; }
  .lspc-32 { letter-spacing: 0.32em; margin-right: -0.32em; }
  .lspc-34 { letter-spacing: 0.34em; margin-right: -0.34em; }
  .lspc-36 { letter-spacing: 0.36em; margin-right: -0.36em; }

  nav.top { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; flex-direction: column; align-items: center; gap: 12px; padding: 22px 56px; background: rgba(239, 233, 220, 0.95); backdrop-filter: blur(6px); color: var(--ink); border-bottom: 0.5px solid rgba(53, 42, 53, 0.08); }
  nav.top .mark { font-family: var(--display); font-size: 20px; }
  nav.top .links { display: flex; gap: 36px; font-size: 11px; text-transform: uppercase; font-weight: 500; }
  nav.top .links a { transition: opacity 0.3s; }
  nav.top .links a:hover { opacity: 0.55; }
  nav.top .links a.current { border-bottom: 0.5px solid var(--ink); padding-bottom: 4px; }

  .page-header { padding: 160px 56px 80px; text-align: center; max-width: 760px; margin: 0 auto; }
  .page-header .crumb { font-size: 11px; text-transform: uppercase; color: var(--stone); margin-bottom: 28px; }
  .page-header h1 { font-family: var(--display); font-size: clamp(48px, 7vw, 88px); font-weight: 400; line-height: 1; color: var(--ink); }
  .page-header .subline { margin-top: 24px; font-size: 17px; color: var(--ink-soft); }

  .hero-strip { width: 100%; aspect-ratio: 21/9; overflow: hidden; background: #2a201d; }
  .hero-strip img { width: 100%; height: 100%; object-fit: cover; object-position: center 60%; }
  @media (min-width: 881px) { .hero-strip { aspect-ratio: 3/2; } }

  .reveal { opacity: 0; transform: translateY(28px); transition: opacity 1.1s ease-out, transform 1.1s ease-out; }
  .reveal.in { opacity: 1; transform: translateY(0); }

  section { padding: 140px 56px; }

  /* Intro */
  .intro { max-width: 720px; margin: 0 auto; text-align: center; }
  .intro h2 { font-family: var(--display); font-size: clamp(34px, 5vw, 56px); line-height: 1.2; margin-bottom: 40px; font-weight: 400; }
  .intro p { font-size: 18px; line-height: 1.85; }
  .intro p + p { margin-top: 22px; }

  /* Event types */
  .types { background: var(--bg-soft); }
  .types .header { text-align: center; margin-bottom: 80px; }
  .types .label { font-size: 11px; text-transform: uppercase; color: var(--stone); margin-bottom: 18px; }
  .types h2 { font-family: var(--display); font-size: clamp(34px, 5vw, 56px); font-weight: 400; line-height: 1.2; color: var(--ink); }
  .types-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; max-width: 1500px; margin: 0 auto; }
  .type-card { display: block; }
  .type-frame { aspect-ratio: 4/5; overflow: hidden; background: #b8a98c; border-radius: var(--radius); margin-bottom: 22px; }
  .type-frame img { width: 100%; height: 100%; object-fit: cover; transition: transform 1.6s ease; }
  .type-card:hover .type-frame img { transform: scale(1.03); }
  .type-card h3 { font-family: var(--display); font-size: 22px; font-weight: 400; margin-bottom: 10px; color: var(--ink); }
  .type-card p { font-size: 14px; line-height: 1.7; color: var(--ink-soft); }

  /* Editorial break */
  .break { height: 70vh; position: relative; overflow: hidden; background-image: url('/img/sandstone-detail.jpg'); background-size: cover; background-position: center center; }
  .break::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(20,15,15,0.10) 0%, rgba(20,15,15,0) 60%); }

  /* What's included */
  .included { max-width: 980px; margin: 0 auto; }
  .included .header { text-align: center; margin-bottom: 64px; }
  .included .label { font-size: 11px; text-transform: uppercase; color: var(--stone); margin-bottom: 18px; }
  .included h2 { font-family: var(--display); font-size: clamp(34px, 5vw, 56px); font-weight: 400; line-height: 1.2; }
  .included-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px 80px; }
  .included-row h3 { font-family: var(--display); font-size: 24px; font-weight: 400; margin-bottom: 12px; }
  .included-row p { font-size: 15px; line-height: 1.8; color: var(--ink-soft); }

  /* Closer */
  .closer-section { padding: 140px 56px 180px; text-align: center; }
  .closer h2 { font-family: var(--display); font-size: clamp(30px, 4.4vw, 52px); line-height: 1.25; margin-bottom: 48px; font-weight: 400; }
  .cta { display: inline-block; background: var(--ink); color: var(--bg); padding: 20px 60px; border-radius: var(--radius); font-size: 11px; text-transform: uppercase; transition: background 0.4s ease, transform 0.4s ease; }
  .cta:hover { background: #241A24; transform: translateY(-1px); }
  .closer-byline { margin-top: 36px; font-size: 11px; text-transform: uppercase; color: var(--stone); }

  footer { background: var(--ink); color: var(--bg); padding: 96px 56px 48px; }
  .foot-top { max-width: 1400px; margin: 0 auto 72px; text-align: center; padding-bottom: 48px; border-bottom: 0.5px solid rgba(239, 233, 220, 0.15); }
  .foot-mark { font-family: var(--display); font-size: 44px; margin-bottom: 18px; letter-spacing: 0.18em; padding-left: 0.18em; display: inline-block; }
  .foot-philo { font-family: var(--display); font-size: 15px; opacity: 0.7; line-height: 1.7; letter-spacing: 0.02em; }
  .foot-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 56px; max-width: 1400px; margin: 0 auto; }
  .foot-col { text-align: center; }
  .foot-h { font-size: 10px; text-transform: uppercase; opacity: 0.55; margin-bottom: 18px; }
  .foot-line { font-size: 14px; line-height: 1.9; opacity: 0.88; display: block; }
  .foot-line:hover { opacity: 0.6; transition: opacity 0.3s; }
  .foot-meta { max-width: 1400px; margin: 80px auto 0; padding-top: 32px; border-top: 0.5px solid rgba(239, 233, 220, 0.15); display: flex; flex-direction: row; flex-wrap: wrap; justify-content: center; align-items: center; gap: 10px 28px; text-align: center; font-size: 11px; text-transform: uppercase; opacity: 0.5; }
  .foot-meta a { border-bottom: 0.5px solid rgba(239, 233, 220, 0.3); padding-bottom: 1px; }

  @media (max-width: 880px) {
    nav.top { padding: 14px 20px; flex-wrap: wrap; row-gap: 8px; }
    nav.top .mark { font-size: 17px; }
    nav.top .links { width: 100%; justify-content: center; gap: 16px; font-size: 10px; }
    nav.top .links .lspc-28 { letter-spacing: 0.08em; margin-right: -0.08em; }
    .page-header { padding: 120px 24px 56px; }
    section { padding: 80px 24px; }
    .types-grid { grid-template-columns: 1fr 1fr; gap: 20px; }
    .included-grid { grid-template-columns: 1fr; gap: 40px; }
    .foot-grid { grid-template-columns: 1fr; gap: 40px; }
    .foot-mark { font-size: 34px; }
    footer { padding: 64px 24px 32px; }
    .foot-meta { flex-direction: column; gap: 12px; font-size: 12px; } .foot-line { font-size: 15px; } .foot-h { font-size: 11px; }
  }
</style>
