---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const galleries = (await getCollection('galleries')).sort((a,b)=>a.data.order-b.data.order);
const tlist = await getCollection('testimonials');
const t = tlist.find(x=>x.data.show_on==='weddings') || tlist[0];
const quote = t ? t.body.trim() : '';
const galleriesData = Object.fromEntries(galleries.map(g=>[g.id, { title: g.data.title, images: g.data.images.map(i=>'/'+i) }]));
---
<BaseLayout title="Weddings · Japonica" description="Garden-inspired wedding floristry for Sydney — bouquets, ceremony pieces, tablescapes and ceiling installations. By appointment, from Ryde." current="weddings" fontItalic={true}>
  <header class="page-header">
    <div class="crumb"><span class="lspc lspc-32">Japonica &middot; The work</span></div>
    <h1>Weddings</h1>
    <p class="subline">Garden-inspired floristry for Sydney weddings and considered events. By appointment only, from a studio in Ryde.</p>
  </header>

  <div class="hero-strip wed">
    <img src="/img/hero-weddings.jpg" alt="Statement ceremony installation — a ground floral nest overlooking the water" />
  </div>

  <section class="intro-section">
    <div class="intro">
      <h2 class="reveal">Wedding philosophy</h2>
      <p class="reveal">Natural, garden-inspired floristry shaped by the season, your venue and your story. From the bouquet in your hands to the centrepieces that gather loved ones around the table, every floral detail is thoughtfully considered and artfully created.</p>
      <p class="reveal">Designed with a relaxed elegance, each arrangement is prepared as close to your wedding day as possible, allowing the flowers to be enjoyed at their freshest and most beautiful.</p>
    </div>
  </section>

  <section class="signature">
    <div class="sig-header">
      <div class="label reveal"><span class="lspc lspc-36">Signature elements</span></div>
      <h2 class="reveal">From the bouquet to the install</h2>
    </div>
    <div class="elements-grid reveal">
      {galleries.map(g => (
        <button type="button" class="element" data-gallery={g.id}>
          <div class="element-frame"><img src={`/${g.data.cover}`} alt={g.data.title} /><span class="element-cue"><span class="lspc lspc-22">View gallery</span></span></div>
          <h3>{g.data.title}</h3>
          <p>{g.data.blurb}</p>
        </button>
      ))}
    </div>
  </section>

  <section class="process-section">
    <div class="process">
      <div class="proc-header">
        <div class="label reveal"><span class="lspc lspc-36">The process</span></div>
        <h2 class="reveal">How it works</h2>
      </div>
      <div class="narrative-body">
        <p class="reveal">We begin with your venue, the season, and the vision you have for your day. From there, we thoughtfully shape a floral design that feels uniquely yours, refining every detail together in the months leading up to your wedding.</p>
      </div>
      <div class="process-footer reveal">
        <a href="/process/" class="process-link"><span class="lspc lspc-28">See the full six-step process</span></a>
      </div>
    </div>
  </section>

  <section class="testimonial-section">
    <div class="testimonial">
      <div class="quote-glyph reveal">&ldquo;</div>
      <div class="quote-body reveal">{quote}</div>
      <div class="quote-attr reveal"><span class="lspc lspc-34">{t?.data.author}</span></div>
    </div>
  </section>

  <section class="closer-section">
    <div class="closer">
      <h2 class="reveal">Let's begin</h2>
      <a href="/enquire/" class="cta reveal"><span class="lspc lspc-36">Begin a conversation</span></a>
      <div class="closer-byline reveal"><span class="lspc lspc-32">By appointment, from Ryde</span></div>
    </div>
  </section>

  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Gallery">
    <div class="lb-bar">
      <span class="lb-title" id="lbTitle"></span>
      <span class="lb-count" id="lbCount"></span>
      <button type="button" class="lb-close" id="lbClose" aria-label="Close gallery">&times;</button>
    </div>
    <div class="lb-stage">
      <button type="button" class="lb-nav" id="lbPrev" aria-label="Previous image">&#8249;</button>
      <img class="lb-img" id="lbImg" src="" alt="" />
      <button type="button" class="lb-nav" id="lbNext" aria-label="Next image">&#8250;</button>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ galleries: galleriesData }}>
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lbImg');
  const lbTitle = document.getElementById('lbTitle');
  const lbCount = document.getElementById('lbCount');
  let current = [], idx = 0;
  function render(){ lbImg.src = current[idx]; lbCount.textContent = (idx+1)+' / '+current.length; }
  function open(key){ const g = galleries[key]; if(!g) return; current = g.images; idx = 0; lbTitle.textContent = g.title; render(); lb.classList.add('open'); document.body.style.overflow='hidden'; }
  function close(){ lb.classList.remove('open'); document.body.style.overflow=''; }
  function step(n){ idx = (idx+n+current.length)%current.length; render(); }
  document.querySelectorAll('.element[data-gallery]').forEach(b=>b.addEventListener('click',()=>open(b.dataset.gallery)));
  document.getElementById('lbClose').addEventListener('click', close);
  document.getElementById('lbPrev').addEventListener('click', ()=>step(-1));
  document.getElementById('lbNext').addEventListener('click', ()=>step(1));
  lb.addEventListener('click', e=>{ if(e.target===lb) close(); });
  document.addEventListener('keydown', e=>{ if(!lb.classList.contains('open')) return; if(e.key==='Escape') close(); else if(e.key==='ArrowLeft') step(-1); else if(e.key==='ArrowRight') step(1); });
</script>

<style>
  .hero-strip.wed img { object-position: center 82%; }
  .intro-section { padding: 96px 56px; }
  .intro { max-width: 720px; margin: 0 auto; text-align: center; }
  .intro h2 { font-family: var(--display); font-size: clamp(34px,5vw,56px); line-height: 1.2; margin-bottom: 40px; font-weight: 400; }
  .intro p { font-size: 18px; line-height: 1.85; }
  .intro p + p { margin-top: 22px; }
  .signature { padding: 96px 56px; background: var(--bg-soft); }
  .sig-header { text-align: center; margin-bottom: 80px; }
  .sig-header .label { font-size: 11px; text-transform: uppercase; color: var(--stone); margin-bottom: 18px; }
  .sig-header h2 { font-family: var(--display); font-size: clamp(34px,5vw,56px); font-weight: 400; line-height: 1.2; color: var(--ink); }
  .elements-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 28px; max-width: 1500px; margin: 0 auto; align-items: start; }
  button.element { appearance: none; border: 0; background: transparent; padding: 0; margin: 0; font: inherit; color: inherit; text-align: left; width: 100%; cursor: pointer; }
  .element-frame { position: relative; aspect-ratio: 4/5; overflow: hidden; background: #b8a98c; border-radius: var(--radius); margin-bottom: 22px; }
  .element-frame img { width: 100%; height: 100%; object-fit: cover; transition: transform 1.6s ease; }
  .element:hover .element-frame img { transform: scale(1.03); }
  .element-cue { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(20,15,15,0.32); color: var(--bg); font-size: 11px; text-transform: uppercase; opacity: 0; transition: opacity 0.4s ease; }
  button.element:hover .element-cue, button.element:focus-visible .element-cue { opacity: 1; }
  button.element:focus-visible { outline: 2px solid var(--ink); outline-offset: 4px; }
  .element h3 { font-family: var(--display); font-size: 22px; font-weight: 400; margin-bottom: 10px; color: var(--ink); }
  .element p { font-size: 14px; line-height: 1.7; color: var(--ink-soft); }
  .process-section { padding: 96px 56px; }
  .process { max-width: 1100px; margin: 0 auto; }
  .proc-header { text-align: center; margin-bottom: 64px; }
  .proc-header .label { font-size: 11px; text-transform: uppercase; color: var(--stone); margin-bottom: 18px; }
  .proc-header h2 { font-family: var(--display); font-size: clamp(34px,5vw,56px); font-weight: 400; line-height: 1.2; }
  .narrative-body { max-width: 720px; margin: 0 auto; text-align: center; }
  .narrative-body p { font-size: 18px; line-height: 1.85; color: var(--ink); }
  .process-footer { text-align: center; margin-top: 48px; }
  .process-link { font-size: 12px; text-transform: uppercase; color: var(--ink); border-bottom: 0.5px solid rgba(53,42,53,0.35); padding-bottom: 4px; transition: opacity 0.3s; }
  .process-link:hover { opacity: 0.6; }
  .testimonial-section { padding: 72px 56px; }
  .closer-section { padding: 80px 56px 132px; text-align: center; }
  .closer h2 { font-family: var(--display); font-size: clamp(30px,4.4vw,52px); line-height: 1.25; margin-bottom: 48px; font-weight: 400; }
  .closer-byline { margin-top: 36px; font-size: 11px; text-transform: uppercase; color: var(--stone); }
  @media (max-width: 880px) {
    .intro-section, .process-section { padding: 56px 24px; }
    .signature { padding: 56px 24px; }
    .testimonial-section { padding: 48px 24px; }
    .closer-section { padding: 56px 24px 88px; }
    .elements-grid { grid-template-columns: 1fr 1fr; gap: 20px; }
  }
</style>
