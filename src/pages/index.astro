---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const studio = (await getCollection('studio')).sort((a,b)=>a.data.order-b.data.order);
const tlist = await getCollection('testimonials');
const t = tlist.find(x=>x.data.show_on==='home') || tlist[0];
const quote = t ? t.body.trim() : '';
---
<BaseLayout home={true} fontItalic={true}>
  <section class="hero">
    <div class="hero-emblem-line"></div>
    <div class="hero-mark"><span class="lspc lspc-20">JAPONICA</span></div>
    <div class="hero-subline"><span class="lspc lspc-36">Sydney wedding floral studio</span></div>
    <div class="scroll-cue"><span class="lspc lspc-32">Scroll</span></div>
  </section>

  <section class="first-photo">
    <div class="first-photo-frame reveal"><img src="/img/hero-roses.jpg" alt="Japonica white garden roses" /></div>
  </section>

  <section id="about" class="about">
    <div class="philo">
      <div class="philo-display reveal">Textural, botanical, organic and a little wild</div>
      <p class="philo-body reveal">We are Japonica, a small Sydney wedding florist working from a studio in Ryde. For over 10 years we have been designing flowers for couples on their wedding day, alongside private events and celebrations we love just as much.</p>
      <p class="philo-body reveal" style="margin-top:28px;">Our work is garden-style and seasonal, planned around the freshest blooms available the week of your wedding. You bring us the venue and the date. We listen, we ask and we build the florals around the day you have been imagining.</p>
    </div>
  </section>

  <section class="testimonial-section">
    <div class="testimonial">
      <div class="quote-glyph reveal">&ldquo;</div>
      <div class="quote-body reveal">{quote}</div>
      <div class="quote-attr reveal"><span class="lspc lspc-34">{t?.data.author}</span></div>
    </div>
  </section>

  <section class="latest-section">
    <div class="latest-header">
      <div class="latest-label reveal"><span class="lspc lspc-36">Latest</span></div>
      <h2 class="reveal">From the studio</h2>
    </div>
    <div class="ig-grid">
      {studio.map(s => (
        <a href={s.data.link} target="_blank" rel="noopener" class="ig-tile reveal"><img src={`/${s.data.image}`} alt={s.data.alt} loading="lazy" /></a>
      ))}
    </div>
    <div class="latest-footer reveal">
      <a href="https://www.instagram.com/__japonica__" target="_blank" rel="noopener" class="ig-link"><span class="lspc lspc-32">Follow on Instagram</span></a>
    </div>
  </section>

  <section class="closer-section">
    <div class="closer">
      <div class="closer-line reveal">Preferred at Athol Hall</div>
      <div class="closer-venues reveal">Japonica is a Ryde based floral studio servicing the Sydney region and surrounds. A regular at Zest The Spit, Orso Bayside, Gunners Barracks, Pasadena Sydney, Manly Pavilion, Q Station and Botanic House.</div>
      <div class="closer-geo reveal"><span class="lspc lspc-32">Northern Beaches &middot; North Shore &middot; Sydney wedding and event florist</span></div>
      <a href="/enquire/" class="cta reveal"><span class="lspc lspc-36">Begin a conversation</span></a>
      <div class="closer-byline reveal"><span class="lspc lspc-32">By appointment, from Ryde</span></div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { position: relative; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 0 24px;
    background: radial-gradient(ellipse at 50% 30%, rgba(255,250,240,0.5) 0%, rgba(234,224,204,0) 60%), linear-gradient(180deg, var(--bg) 0%, var(--bg-warm) 65%, var(--bg-soft) 100%); }
  .hero-emblem-line { width: 64px; height: 1px; background: var(--ink); margin-bottom: 56px; opacity: 0; transform: scaleX(0); animation: emblem 1.2s 0.2s ease-out forwards; }
  @keyframes emblem { to { opacity: 0.4; transform: scaleX(1); } }
  .hero-mark { font-family: var(--display); font-size: clamp(54px,11vw,168px); font-weight: 400; line-height: 1; color: var(--ink); opacity: 0; transform: translateY(20px); animation: heroIn 1.4s 0.5s ease-out forwards; }
  .hero-subline { margin-top: 80px; font-size: 11px; text-transform: uppercase; color: var(--stone); opacity: 0; animation: heroIn 1.4s 1.5s ease-out forwards; }
  @keyframes heroIn { to { opacity: 1; transform: translateY(0); } }
  .scroll-cue { position: absolute; bottom: 66px; left: 50%; transform: translateX(-50%); color: var(--ink-soft); font-size: 10px; text-transform: uppercase; opacity: 0; animation: heroIn 1.4s 2s ease-out forwards; }
  .scroll-cue::after { content: ""; display: block; width: 1px; height: 32px; background: var(--ink); margin: 12px auto 0; opacity: 0.5; }
  @keyframes bob { 0%,100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(4px); } }
  .first-photo { padding: 0; }
  .first-photo-frame { width: 100%; aspect-ratio: 21/9; overflow: hidden; background: #2a201d; }
  .first-photo-frame img { width: 100%; height: 100%; object-fit: cover; transition: transform 6s ease; }
  .first-photo-frame:hover img { transform: scale(1.03); }
  .about { padding: 40px 56px 56px; }
  .philo { max-width: 760px; margin: 0 auto; text-align: center; }
  .philo-display { font-family: var(--display); font-size: clamp(34px,5.4vw,64px); line-height: 1.15; color: var(--ink); margin-bottom: 56px; }
  .philo-body { font-size: 18px; line-height: 1.85; color: var(--ink); max-width: 580px; margin: 0 auto; }
  .testimonial-section { padding: 56px 56px 120px; }
  .latest-section { padding: 140px 56px; background: var(--bg-soft); }
  .latest-header { text-align: center; margin-bottom: 64px; }
  .latest-label { font-size: 11px; text-transform: uppercase; color: var(--stone); margin-bottom: 18px; }
  .latest-header h2 { font-family: var(--display); font-size: clamp(34px,5vw,56px); font-weight: 400; line-height: 1.2; color: var(--ink); }
  .ig-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; max-width: 1100px; margin: 0 auto; }
  .ig-tile { display: block; aspect-ratio: 1; overflow: hidden; background: #b8a98c; border-radius: var(--radius); }
  .ig-tile img { width: 100%; height: 100%; object-fit: cover; transition: transform 1.6s ease; }
  .ig-tile:hover img { transform: scale(1.05); }
  .latest-footer { text-align: center; margin-top: 56px; }
  .ig-link { display: inline-block; font-size: 12px; text-transform: uppercase; color: var(--ink); border-bottom: 0.5px solid rgba(53,42,53,0.35); padding-bottom: 4px; transition: opacity 0.3s; }
  .ig-link:hover { opacity: 0.6; }
  .closer-section { padding: 140px 56px 180px; }
  .closer { max-width: 820px; margin: 0 auto; text-align: center; }
  .closer-line { font-family: var(--display); font-size: clamp(30px,4.4vw,52px); line-height: 1.25; color: var(--ink); margin-bottom: 28px; }
  .closer-venues { font-size: 17px; line-height: 1.9; color: var(--ink-soft); max-width: 640px; margin: 0 auto 32px; }
  .closer-geo { font-size: 11px; text-transform: uppercase; color: var(--stone); margin: 0 auto 56px; }
  .closer-byline { margin-top: 44px; font-size: 11px; text-transform: uppercase; color: var(--stone); }
  @media (max-width: 880px) {
    .about, .testimonial-section, .latest-section, .closer-section { padding: 96px 24px; }
    .first-photo-frame { aspect-ratio: 4/3; }
    .ig-grid { grid-template-columns: repeat(2,1fr); }
    .closer-section { padding-bottom: 120px; }
  }
</style>
